{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "composer install --working-dir javaloka-app --no-dev --prefer-dist --optimize-autoloader && npm ci --prefix javaloka-app",
  "buildCommand": "npm run build --prefix javaloka-app",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.5.2",
      "includeFiles": "javaloka-app/**"
    }
  },
  "rewrites": [
    {
      "source": "/build/:match*",
      "destination": "/javaloka-app/public/build/:match*"
    },
    {
      "source": "/assets/:match*",
      "destination": "/javaloka-app/public/assets/:match*"
    },
    {
      "source": "/favicon.ico",
      "destination": "/javaloka-app/public/favicon.ico"
    },
    {
      "source": "/robots.txt",
      "destination": "/javaloka-app/public/robots.txt"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.php"
    }
  ]
}
